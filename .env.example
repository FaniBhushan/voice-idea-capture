# Gemini API Key (required for note enrichment)
GEMINI_API_KEY=your_gemini_api_key_here

# Obsidian Vault Path (optional - defaults to ./obsidian_vault in the project root)
# Can point to a subfolder inside your main Obsidian vault
OBSIDIAN_VAULT_PATH=~/Documents/ObsidianVault/voice-idea-capture

# Input Directory where raw voice notes are placed (optional - defaults to ~/.voice-idea-capture/input)
INPUT_DIR=~/.voice-idea-capture/input

# Processed Directory where completed notes are archived (optional - defaults to ~/.voice-idea-capture/processed)
PROCESSED_DIR=~/.voice-idea-capture/processed
